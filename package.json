{
  "name": "vswt",
  "displayName": "vsWT — Worktree Orchestrator",
  "description": "Run parallel Claude Code sessions, each in its own git worktree, from the VS Code sidebar.",
  "version": "0.0.1",
  "publisher": "vana123",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "agents",
    "git worktree",
    "parallel",
    "anthropic"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0f0f0f",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vana123/vswt.git"
  },
  "bugs": {
    "url": "https://github.com/vana123/vswt/issues"
  },
  "homepage": "https://github.com/vana123/vswt#readme",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:vswt.sidebar"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vswt",
          "title": "vsWT",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vswt": [
        {
          "type": "webview",
          "id": "vswt.sidebar",
          "name": "Worktrees",
          "icon": "media/icon.svg",
          "contextualTitle": "vsWT"
        }
      ]
    },
    "commands": [
      {
        "command": "vswt.openSidebar",
        "title": "Open Sidebar",
        "category": "vsWT"
      },
      {
        "command": "vswt.createWorktree",
        "title": "New Worktree…",
        "category": "vsWT",
        "icon": "$(add)"
      },
      {
        "command": "vswt.refreshWorktrees",
        "title": "Refresh",
        "category": "vsWT",
        "icon": "$(refresh)"
      },
      {
        "command": "vswt.pickRepo",
        "title": "Pick Repository…",
        "category": "vsWT",
        "icon": "$(repo)"
      },
      {
        "command": "vswt.startClaudeSession",
        "title": "Start Claude Session",
        "category": "vsWT"
      },
      {
        "command": "vswt.startShellSession",
        "title": "Start Shell Session",
        "category": "vsWT"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vswt.createWorktree",
          "when": "view == vswt.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "vswt.refreshWorktrees",
          "when": "view == vswt.sidebar",
          "group": "navigation@2"
        },
        {
          "command": "vswt.pickRepo",
          "when": "view == vswt.sidebar",
          "group": "1_config@1"
        }
      ]
    },
    "configuration": {
      "title": "vsWT",
      "properties": {
        "vswt.worktree.parentDir": {
          "type": "string",
          "default": "",
          "description": "Parent directory for new worktrees. Empty = sibling folder `../{repo}-worktrees`. Supports `~` expansion."
        },
        "vswt.worktree.copyFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".env",
            ".env.*",
            ".claude/**"
          ],
          "description": "Glob patterns (relative to repo root) copied into a new worktree when the user opts in."
        },
        "vswt.worktree.postCreateCommand": {
          "type": "string",
          "default": "",
          "description": "Shell command run inside the new worktree after creation (e.g. `npm install` or `pnpm i`). Empty to skip."
        },
        "vswt.worktree.runPrismaGenerate": {
          "type": "boolean",
          "default": true,
          "description": "Run `npx prisma generate` if `prisma/schema.prisma` exists in the new worktree."
        },
        "vswt.shell.windows": {
          "type": "string",
          "default": "",
          "description": "Windows shell override for Shell sessions (`pwsh.exe`, `powershell.exe`, `cmd.exe`). Empty = auto."
        },
        "vswt.notifications.sound": {
          "type": "boolean",
          "default": true,
          "description": "Play OS sound on session state transitions (waiting input, approval needed, done)."
        },
        "vswt.claude.path": {
          "type": "string",
          "default": "claude",
          "description": "Path or command name for the Claude Code CLI."
        },
        "vswt.extraShells": {
          "type": "array",
          "default": null,
          "description": "Additional shell options exposed as session buttons (e.g. Git Bash, CMD on Windows). When unset, sensible platform defaults are used; set to [] to hide all extras.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "command"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display label, e.g. \"Git Bash\"."
              },
              "command": {
                "type": "string",
                "description": "Absolute path to the shell binary."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Optional arguments."
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "node-pty": "^1.1.0",
    "preact": "^10.29.1"
  }
}
